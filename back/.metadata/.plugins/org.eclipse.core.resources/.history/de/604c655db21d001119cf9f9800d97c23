package com.example.demo.config;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.security.config.annotation.web.builders.HttpSecurity;
import org.springframework.security.web.SecurityFilterChain;
import com.example.demo.controller.advice.CustomControllerAdvice;
import lombok.RequiredArgsConstructor;
import lombok.extern.log4j.Log4j2;

@Configuration
@Log4j2
@RequiredArgsConstructor
public class CustomSecurityConfig {

    private final CustomControllerAdvice customControllerAdvice;


    CustomSecurityConfig(CustomControllerAdvice customControllerAdvice) {
        this.customControllerAdvice = customControllerAdvice;
    }

	
	@Bean
	public SecurityFilterChain filterChain(HttpSecurity http) throws Exception{
		
		log.info("---------------------securityconfig------------");
		
		return http.build();
	}
}
